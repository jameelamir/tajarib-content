#!/bin/bash
# Spawn the Tajarib Content Agent

task="$1"
if [ -z "$task" ]; then
    echo "Usage: tajarib-agent 'research [guest name] and draft content for [episode]'"
    exit 1
fi

openclaw sessions_spawn \
    --agent-id tajarib-content \
    --task "$task" \
    --label "tajarib-content-$(date +%s)"
